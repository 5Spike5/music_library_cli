// ============================================================
// footer.slint — 底部播放控制栏 (12%)
// ============================================================
// 布局:
//   左侧: 当前播放歌曲名
//   中间: Image skip-back | Image play/pause-circle | Image skip-forward
//   右侧: Image shuffle | Image repeat | 音量 Image + Slider
//
// 图标来源: Phosphor Icons SVG → ui/icons/*.svg
// ============================================================

import { PlayState } from "common.slint";
import { Theme } from "theme.slint";
import { Slider } from "std-widgets.slint";

export component Footer {
    in property <string> now-playing-text: "—";
    in property <PlayState> play-state: PlayState.Stopped;
    in-out property <float> volume: 50.0;
    in-out property <bool> shuffle-on: false;
    in-out property <bool> loop-on: false;

    callback prev-clicked();
    callback play-pause-clicked();
    callback next-clicked();
    callback shuffle-toggled(bool);
    callback loop-toggled(bool);
    callback volume-changed(float);

    height: 100%;
    width: 100%;

    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.footer-bg;

        HorizontalLayout {
            padding-left: 20px;
            padding-right: 20px;
            alignment: center;

            // ===== 左侧：当前播放歌曲名 =====
            Text {
                text: root.now-playing-text;
                color: Theme.footer-text;
                font-size: 13px;
                width: 200px;
                overflow: elide;
                vertical-alignment: center;
            }

            // ===== 弹簧 =====
            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }

            // ====================
            // 中间：播放控制按钮组
            // ====================
            HorizontalLayout {
                spacing: 20px;
                alignment: center;

                // 上一首 ⏮ → skip-back.svg
                prev-touch := TouchArea {
                    height: 22px;
                    clicked => { root.prev-clicked(); }
                    Image {
                        source: @image-url("icons/skip-back.svg");
                        width: 22px;
                        height: 22px;
                        colorize: Theme.footer-text;
                        opacity: prev-touch.pressed ? 0.6 : 1.0;
                    }
                }

                // 播放/暂停 ▶ / ⏸ → play-circle.svg / pause-circle.svg
                // 用 if 互斥：Slint 的 @image-url 是编译期宏，不能放三目表达式
                play-btn := TouchArea {
                    height: 42px;
                    clicked => { root.play-pause-clicked(); }
                    Rectangle {
                        width: 42px;
                        height: 42px;
                        border-radius: 21px;
                        background: transparent;

                        // 暂停状态 → 显示 pause-circle
                        if root.play-state == PlayState.Playing : Image {
                            source: @image-url("icons/pause-circle.svg");
                            width: 26px;
                            height: 26px;
                            colorize: Theme.footer-text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        // 其他状态 → 显示 play-circle
                        if root.play-state != PlayState.Playing : Image {
                            source: @image-url("icons/play-circle.svg");
                            width: 26px;
                            height: 26px;
                            colorize: Theme.footer-text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // 下一首 ⏭ → skip-forward.svg
                next-touch := TouchArea {
                    height: 22px;
                    clicked => { root.next-clicked(); }
                    Image {
                        source: @image-url("icons/skip-forward.svg");
                        width: 22px;
                        height: 22px;
                        colorize: Theme.footer-text;
                        opacity: next-touch.pressed ? 0.6 : 1.0;
                    }
                }
            }

            // ===== 弹簧 =====
            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }

            // ====================
            // 右侧：播放模式 + 音量
            // ====================
            HorizontalLayout {
                spacing: 10px;
                alignment: center;

                // 随机模式 🔀 → shuffle.svg（开=accent色，关=半透明）
                shuffle-touch := TouchArea {
                    height: 18px;
                    clicked => {
                        root.shuffle-on = !root.shuffle-on;
                        root.shuffle-toggled(root.shuffle-on);
                    }
                    Image {
                        source: @image-url("icons/shuffle.svg");
                        width: 18px;
                        height: 18px;
                        colorize: root.shuffle-on ? Theme.accent : Theme.footer-text;
                        opacity: root.shuffle-on ? 1.0 : 0.4;
                    }
                }

                // 循环模式 🔁 → repeat-once.svg
                loop-touch := TouchArea {
                    height: 18px;
                    clicked => {
                        root.loop-on = !root.loop-on;
                        root.loop-toggled(root.loop-on);
                    }
                    Image {
                        source: @image-url("icons/repeat-once.svg");
                        width: 18px;
                        height: 18px;
                        colorize: root.loop-on ? Theme.accent : Theme.footer-text;
                        opacity: root.loop-on ? 1.0 : 0.4;
                    }
                }

                // 音量图标 🔊 → speaker-*.svg（3档切换）
                // 用 Rectangle 固定 18x18 确保在 layout 中不拉伸且垂直居中
                Rectangle {
                    width: 24px;
                    height: 18px;
                    // mute
                    if root.volume == 0.0 : Image {
                        source: @image-url("icons/speaker-x.svg");
                        width: 18px;
                        height: 18px;
                        x: (parent.width - 18px) / 2;
                        colorize: Theme.footer-text;
                        opacity: 0.7;
                    }
                    // 低音量
                    if root.volume > 0.0 && root.volume <= 50.0 : Image {
                        source: @image-url("icons/speaker-low.svg");
                        width: 18px;
                        height: 18px;
                        x: (parent.width - 18px) / 2;
                        colorize: Theme.footer-text;
                        opacity: 0.7;
                    }
                    // 高音量
                    if root.volume > 50.0 : Image {
                        source: @image-url("icons/speaker-high.svg");
                        width: 18px;
                        height: 18px;
                        x: (parent.width - 18px) / 2;
                        colorize: Theme.footer-text;
                        opacity: 0.7;
                    }
                }

                // 音量滑块
                vol-slider := Slider {
                    minimum: 0.0;
                    maximum: 100.0;
                    value <=> root.volume;
                    width: 80px;
                    changed(vol) => {
                        root.volume-changed(vol);
                    }
                }
            }
        }
    }
}
