// ============================================================
// Header
// ============================================================
// Layout:
// [Title] ................................ [Toolbar Group]
//
// Toolbar Group:
// [Search capsule] [Scan capsule] [Theme capsule]
//
// Notes:
// - Search uses TextInput instead of LineEdit so we can fully control
//   the visual style and avoid the native Windows clear button / frame.
// - Rust can connect to the callbacks below.
// ============================================================

import { ThemeMode } from "theme.slint";
import { Theme } from "theme.slint";

export component Header {
    in property <string> window-title: "Music Library";

    callback search-submitted(string);
    callback scan-folder-clicked();

    height: 100%;
    width: 100%;

    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;

        HorizontalLayout {
            width: parent.width;
            height: 52px;
            y: (parent.height - 52px) / 2;
            padding-left: 22px;
            padding-right: 22px;
            spacing: 16px;

            Text {
                text: window-title;
                color: Theme.text-main;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }

            Rectangle {
                width: 592px;
                height: 52px;
                border-radius: 26px;
                background: Theme.toolbar-group-bg;
                border-width: 1px;
                border-color: Theme.toolbar-group-border;

                HorizontalLayout {
                    width: parent.width;
                    height: 40px;
                    y: (parent.height - 40px) / 2;
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 10px;

                    Rectangle {
                        width: 338px;
                        height: 40px;
                        background: transparent;

                        search-shell := Rectangle {
                            width: parent.width;
                            height: parent.height;
                            border-radius: 20px;
                            background: Theme.search-bg;
                            border-width: 1px;
                            border-color: search-input.has-focus ? Theme.accent : Theme.search-border;

                            if search-input.has-focus : Rectangle {
                                x: -2px;
                                y: -2px;
                                width: parent.width + 4px;
                                height: parent.height + 4px;
                                border-radius: 22px;
                                background: transparent;
                                border-width: 2px;
                                border-color: Theme.search-focus-ring;
                            }

                            Image {
                                source: @image-url("icons/magnifying-glass.svg");
                                x: 14px;
                                y: 11px;
                                width: 18px;
                                height: 18px;
                                colorize: Theme.search-icon;
                                opacity: search-input.has-focus ? 0.95 : 0.78;
                            }

                            if search-input.text.is-empty : Text {
                                x: 42px;
                                y: 0px;
                                width: 210px;
                                height: parent.height;
                                text: "Search songs, artists, or paths";
                                color: Theme.search-placeholder;
                                font-size: 14px;
                                vertical-alignment: center;
                            }

                            search-input := TextInput {
                                x: 42px;
                                y: 5px;
                                width: parent.width - 80px;
                                height: 30px;
                                text: "";
                                color: Theme.text-main;
                                font-size: 14px;
                                font-weight: 500;
                                vertical-alignment: center;
                                single-line: true;
                                selection-background-color: Theme.accent;
                                selection-foreground-color: #FFFFFF;
                                accepted => {
                                    root.search-submitted(search-input.text);
                                }
                            }

                            if !search-input.text.is-empty : Rectangle {
                                width: 18px;
                                height: 18px;
                                x: parent.width - 30px;
                                y: 11px;
                                border-radius: 9px;
                                background: clear-touch.pressed ? Theme.hover-bg : Theme.toolbar-chip-border;

                                clear-touch := TouchArea {
                                    width: 18px;
                                    height: 18px;
                                    clicked => {
                                        search-input.text = "";
                                        search-input.focus();
                                    }
                                }

                                Text {
                                    text: "×";
                                    width: 100%;
                                    height: 100%;
                                    color: Theme.search-icon;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle {
                        width: 96px;
                        height: 40px;
                        border-radius: 20px;
                        background: scan-touch.pressed ? Theme.hover-bg : Theme.search-bg;
                        border-width: 1px;
                        border-color: Theme.search-border;

                        scan-touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.scan-folder-clicked();
                            }
                        }

                        Image {
                            source: @image-url("icons/folder-open.svg");
                            x: 14px;
                            y: 11px;
                            width: 18px;
                            height: 18px;
                            colorize: Theme.text-main;
                            opacity: scan-touch.pressed ? 0.56 : 0.84;
                        }

                        Text {
                            x: 39px;
                            y: 0px;
                            width: 42px;
                            height: parent.height;
                            text: "Scan";
                            color: Theme.text-main;
                            font-size: 13px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 132px;
                        height: 40px;
                        border-radius: 20px;
                        background: Theme.toolbar-chip-bg;
                        border-width: 1px;
                        border-color: Theme.toolbar-chip-border;

                        HorizontalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;

                            Rectangle {
                                width: 24px;
                                height: 40px;
                                background: transparent;

                                light-touch := TouchArea {
                                    x: 0px;
                                    y: 8px;
                                    width: 24px;
                                    height: 24px;
                                    clicked => { Theme.mode = ThemeMode.light; }

                                    if Theme.mode == ThemeMode.light : Rectangle {
                                        x: 0px;
                                        y: 0px;
                                        width: 24px;
                                        height: 24px;
                                        border-radius: 12px;
                                        background: Theme.hover-bg;
                                    }

                                    Rectangle {
                                        x: 4px;
                                        y: 4px;
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 8px;
                                        background: #FAFAFA;
                                        border-width: Theme.mode == ThemeMode.light ? 2px : 0px;
                                        border-color: Theme.accent;
                                    }
                                }
                            }

                            Rectangle {
                                width: 24px;
                                height: 40px;
                                background: transparent;

                                dark-touch := TouchArea {
                                    x: 0px;
                                    y: 8px;
                                    width: 24px;
                                    height: 24px;
                                    clicked => { Theme.mode = ThemeMode.dark; }

                                    if Theme.mode == ThemeMode.dark : Rectangle {
                                        x: 0px;
                                        y: 0px;
                                        width: 24px;
                                        height: 24px;
                                        border-radius: 12px;
                                        background: Theme.hover-bg;
                                    }

                                    Rectangle {
                                        x: 4px;
                                        y: 4px;
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 8px;
                                        background: #121212;
                                        border-width: Theme.mode == ThemeMode.dark ? 2px : 0px;
                                        border-color: Theme.accent;
                                    }
                                }
                            }

                            Rectangle {
                                width: 24px;
                                height: 40px;
                                background: transparent;

                                amber-touch := TouchArea {
                                    x: 0px;
                                    y: 8px;
                                    width: 24px;
                                    height: 24px;
                                    clicked => { Theme.mode = ThemeMode.amber; }

                                    if Theme.mode == ThemeMode.amber : Rectangle {
                                        x: 0px;
                                        y: 0px;
                                        width: 24px;
                                        height: 24px;
                                        border-radius: 12px;
                                        background: Theme.hover-bg;
                                    }

                                    Rectangle {
                                        x: 4px;
                                        y: 4px;
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 8px;
                                        background: #FDF6EE;
                                        border-width: Theme.mode == ThemeMode.amber ? 2px : 0px;
                                        border-color: Theme.accent;
                                    }
                                }
                            }

                            Rectangle {
                                width: 24px;
                                height: 40px;
                                background: transparent;

                                dusk-touch := TouchArea {
                                    x: 0px;
                                    y: 8px;
                                    width: 24px;
                                    height: 24px;
                                    clicked => { Theme.mode = ThemeMode.dusk; }

                                    if Theme.mode == ThemeMode.dusk : Rectangle {
                                        x: 0px;
                                        y: 0px;
                                        width: 24px;
                                        height: 24px;
                                        border-radius: 12px;
                                        background: Theme.hover-bg;
                                    }

                                    Rectangle {
                                        x: 4px;
                                        y: 4px;
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 8px;
                                        background: #1B1B2F;
                                        border-width: Theme.mode == ThemeMode.dusk ? 2px : 0px;
                                        border-color: Theme.accent;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
