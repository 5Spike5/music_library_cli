// ============================================================
// theme.slint — 全局主题系统
// ============================================================

export enum ThemeMode {
    light,       // 月白
    dark,        // 极夜
    amber,       // 琥珀
    dusk,        // 暮紫
}

export global Theme {
    in-out property <ThemeMode> mode: ThemeMode.dark;

    // ── 主底色 ──
    out property <brush> window-bg:
        mode == ThemeMode.light  ? #FAFAFA :
        mode == ThemeMode.dark   ? #121212 :
        mode == ThemeMode.amber  ? #FDF6EE :
        #1B1B2F;

    // ── 顶栏 ──
    out property <brush> header-bg:
        mode == ThemeMode.light  ? #F0F0F0 :
        mode == ThemeMode.dark   ? #1A1A1A :
        mode == ThemeMode.amber  ? #F5E6D3 :
        #232340;

    // ── 左侧导航栏 ──
    out property <brush> nav-bg:
        mode == ThemeMode.light  ? #F5F5F5 :
        mode == ThemeMode.dark   ? #0F0F0F :
        mode == ThemeMode.amber  ? #F0DCC0 :
        #151528;

    // ── 中间歌曲列表 ──
    out property <brush> list-bg:
        mode == ThemeMode.light  ? #FFFFFF :
        mode == ThemeMode.dark   ? #161616 :
        mode == ThemeMode.amber  ? #FFFBF6 :
        #1E1E33;

    // ── 右侧详情 ──
    out property <brush> detail-bg:
        mode == ThemeMode.light  ? #F8F8F8 :
        mode == ThemeMode.dark   ? #1E1E1E :
        mode == ThemeMode.amber  ? #F8EDDC :
        #282844;

    // ── 底部控制栏 ──
    out property <brush> footer-bg:
        mode == ThemeMode.light  ? #E8E8E8 :
        mode == ThemeMode.dark   ? #282828 :
        mode == ThemeMode.amber  ? #8B5E3C :
        #0E0E1A;

    // ── 主文字色 ──
    out property <brush> text-main:
        mode == ThemeMode.light  ? #1A1A1A :
        mode == ThemeMode.dark   ? #E0E0E0 :
        mode == ThemeMode.amber  ? #3A2B1E :
        #E0DBF0;

    // ── 次要文字色（比主文字淡一档） ──
    out property <brush> text-sub:
        mode == ThemeMode.light  ? #888888 :
        mode == ThemeMode.dark   ? #999999 :
        mode == ThemeMode.amber  ? #8C7A6A :
        #968EB8;

    // ── 选中高亮色 ──
    out property <brush> accent:
        mode == ThemeMode.light  ? #1DB954 :
        mode == ThemeMode.dark   ? #1DB954 :
        mode == ThemeMode.amber  ? #D4893A :
        #7B68EE;

    // ── 分割线 ──
    out property <brush> divider:
        mode == ThemeMode.light  ? #E0E0E0 :
        mode == ThemeMode.dark   ? #2A2A2A :
        mode == ThemeMode.amber  ? #E8D5C0 :
        #2A2A3A;

    // ── 按钮悬停色 ──
    out property <brush> hover-bg:
        mode == ThemeMode.light  ? #E8E8E8 :
        mode == ThemeMode.dark   ? #2A2A2A :
        mode == ThemeMode.amber  ? #F0DCC0 :
        #2A2A3A;

    // ── 搜索框背景 ──
    out property <brush> search-bg:
        mode == ThemeMode.light  ? #FFFFFFCC :
        mode == ThemeMode.dark   ? #2A2A2A :
        mode == ThemeMode.amber  ? #FFF7ED :
        #303050;

    // ── 搜索框边框 ──
    out property <brush> search-border:
        mode == ThemeMode.light  ? #D9D9D9 :
        mode == ThemeMode.dark   ? #3A3A3A :
        mode == ThemeMode.amber  ? #E2C9AB :
        #4A4A74;

    // ── 搜索框聚焦高亮 ──
    out property <brush> search-focus-ring:
        mode == ThemeMode.light  ? #1DB95455 :
        mode == ThemeMode.dark   ? #1DB95466 :
        mode == ThemeMode.amber  ? #D4893A66 :
        #7B68EE66;

    // ── 搜索框占位/图标 ──
    out property <brush> search-placeholder:
        mode == ThemeMode.light  ? #8D8D8D :
        mode == ThemeMode.dark   ? #A0A0A0 :
        mode == ThemeMode.amber  ? #947B65 :
        #A7A0CA;

    out property <brush> search-icon:
        mode == ThemeMode.light  ? #6F6F6F :
        mode == ThemeMode.dark   ? #B8B8B8 :
        mode == ThemeMode.amber  ? #7F6855 :
        #C6BFF0;

    out property <brush> toolbar-group-bg:
        mode == ThemeMode.light  ? #FFFFFF88 :
        mode == ThemeMode.dark   ? #171717DD :
        mode == ThemeMode.amber  ? #FFF8EF :
        #23233BCC;

    out property <brush> toolbar-group-border:
        mode == ThemeMode.light  ? #DCDCDC :
        mode == ThemeMode.dark   ? #2E2E2E :
        mode == ThemeMode.amber  ? #E7CBAA :
        #3E3E63;

    out property <brush> toolbar-chip-bg:
        mode == ThemeMode.light  ? #FFFFFF99 :
        mode == ThemeMode.dark   ? #232323 :
        mode == ThemeMode.amber  ? #FFF3E0 :
        #2A2A44;

    out property <brush> toolbar-chip-border:
        mode == ThemeMode.light  ? #D7D7D7 :
        mode == ThemeMode.dark   ? #343434 :
        mode == ThemeMode.amber  ? #E2C5A0 :
        #47476D;

    // ── Footer 文字色（某些主题 footer 深色需要浅字） ──
    out property <brush> footer-text:
        mode == ThemeMode.light  ? #1A1A1A :
        mode == ThemeMode.dark   ? #E0E0E0 :
        mode == ThemeMode.amber  ? #FAFAFA :
        #E0DBF0;
}
